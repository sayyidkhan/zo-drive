# Must be outside this Git repository.
ZO_DRIVE_DATA_ROOT=/Users/your-user/Library/Application Support/zo-drive-data
# Required in production. Generate with: openssl rand -base64 48
ZO_DRIVE_SESSION_SECRET=replace-with-a-random-secret-at-least-32-characters
ZO_DRIVE_PORT=43071
ZO_DRIVE_ALLOWED_ORIGIN=http://127.0.0.1:43072
# Rate-limit settings belong in config.json; start from config.example.json.
